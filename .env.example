# Supabase Postgres (ใช้กับ Prisma)
# ดูได้จาก Supabase Dashboard → Project Settings → Database → Connection string
# - DATABASE_URL ใช้ connection pooler (port 6543) สำหรับ runtime
# - DIRECT_URL ใช้ direct connection (port 5432) สำหรับ prisma migrate
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Client (สำหรับ Auth ใน browser/server)
# ดูจาก Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Supabase Service Role Key (server-only) — ใช้สำหรับ admin invite/disable user ใน /admin/users
# ดูจาก Project Settings → API → service_role
# ห้ามเปิดเผยใน client-side ใดๆ
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Bootstrap admin emails (คั่นด้วย comma) — ใช้ตอน prisma db:seed เท่านั้น
# user เหล่านี้ต้องถูก invite/สร้างใน Supabase Auth ก่อน แล้ว seed จะอัปเกรดเป็น role=ADMIN
ADMIN_EMAILS="you@example.com"

# Anajak Order → Sheet (Gemini API)
# ใช้ใน /api/anajak/parse — ขอจาก https://aistudio.google.com/apikey
GEMINI_API_KEY=""
